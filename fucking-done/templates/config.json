{
  "mode": "interactive",
  "depth": "standard",
  "parallelization": true,
  "commit_docs": true,
  "model_profile": "balanced",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "difficulty_aware": true
  },
  "agent_team": {
    "lead_model": "opus",
    "teammate_model": "sonnet",
    "max_gap_loops": 3,
    "max_parallel": 4,
    "isolation": "shared"
  },
  "repair": {
    "max_retries": 2,
    "backoff": "none",
    "timeout_minutes": 30,
    "idempotency": true
  },
  "aid": {
    "enabled": false,
    "include": "",
    "exclude": "*test*,*spec*,*.config.*,node_modules,vendor",
    "flags": "--format md",
    "src_path": ""
  }
}
